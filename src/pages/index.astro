---
import HomeTemplate from '../templates/HomeTemplate.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'home');
if (!entry) throw new Error('home.md not found');

interface HeroData { headline: string[]; tagline: string; }
interface ServiceData { title: string; description: string; href: string; }
interface MissionData { heading: string; body: string; visio: string; }
interface ValueData { title: string; description: string; }
interface CtaData { heading: string; label: string; href: string; }
interface HomeData {
  hero: HeroData;
  services: ServiceData[];
  mission: MissionData;
  values: ValueData[];
  cta: CtaData;
}

const data = entry.data as unknown as HomeData;
---

<HomeTemplate
  lang="ca"
  data={data}
  pageTitle="Àbiòtic — Consultoria Ambiental a Andorra"
  pageDescription="Gestió de xarxes d'aigua, consultoria ambiental i enginyeria a Andorra. Àbiòtic ofereix serveis tècnics de qualitat per a empreses i administracions."
/>
