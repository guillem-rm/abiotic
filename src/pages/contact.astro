---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import ContactDetail from '../components/ContactDetail.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'contact');
if (!entry) throw new Error('contact.md not found');

interface ContactData {
  intro: string;
  address: { street: string; city: string; country: string };
  phones: string[];
  email: string;
  instagram: string;
}

const { intro, address, phones, email, instagram } = entry.data as unknown as ContactData;
---

<BaseLayout
  title="Contacte — Àbiòtic"
  description="Posa't en contacte amb Àbiòtic per a qualsevol consulta sobre serveis ambientals a Andorra. Telèfon, email i formulari de contacte."
>

  <!-- Hero — editorial, consistent with home -->
  <section class="relative bg-white overflow-hidden border-b border-stone-100">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image: linear-gradient(to right, #e7e5e4 1px, transparent 1px), linear-gradient(to bottom, #e7e5e4 1px, transparent 1px); background-size: 80px 80px; opacity: 0.35;"
    ></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-8 h-px bg-secondary-500"></div>
        <span class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em]">Contacte</span>
      </div>
      <h1 class="font-display text-5xl sm:text-6xl font-medium text-stone-900 leading-[1.15] max-w-lg">
        Parlem del teu<br /><em class="font-normal italic text-brand-700">projecte.</em>
      </h1>
      <p class="mt-6 text-stone-500 text-lg leading-relaxed max-w-xl">{intro}</p>
    </div>
  </section>

  <!-- Form + Contact info -->
  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 lg:gap-0 border border-stone-200">

        <!-- Form (7 cols) -->
        <div class="lg:col-span-7 p-8 lg:p-12 border-b lg:border-b-0 lg:border-r border-stone-200">

          <!-- Section label -->
          <div class="flex items-baseline justify-between pb-7 mb-10 border-b border-stone-200">
            <h2 class="font-display text-2xl font-medium text-stone-900">Envia'ns un missatge</h2>
          </div>

          <!-- Success message -->
          <div id="success-message" class="hidden border-l-2 border-brand-500 bg-brand-50 px-8 py-10">
            <p class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em] mb-3">Missatge enviat</p>
            <p class="font-display text-2xl font-medium text-stone-900 mb-2">Gràcies pel teu contacte.</p>
            <p class="text-stone-500 text-sm leading-relaxed">Ens posarem en contacte amb tu tan aviat com sigui possible.</p>
          </div>

          <div id="form-container">
            <ContactForm netlifyFormName="contact" />
          </div>
        </div>

        <!-- Contact info panel (5 cols) — dark brand panel -->
        <div class="lg:col-span-5 bg-brand-700 p-8 lg:p-12 flex flex-col">

          <div class="pb-7 mb-10 border-b border-white/10">
            <h2 class="font-display text-xl font-medium text-white">Informació de contacte</h2>
          </div>

          <div class="space-y-8 flex-1">

            <!-- Adreça -->
            <div>
              <p class="text-brand-200 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">Adreça</p>
              <p class="text-white text-sm leading-relaxed">
                {address.street}<br />
                {address.city}<br />
                {address.country}
              </p>
            </div>

            <div class="w-full h-px bg-white/10"></div>

            <!-- Telèfon -->
            <div>
              <p class="text-brand-200 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">Telèfon</p>
              <div class="space-y-1">
                {phones.map((phone) => (
                  <a
                    href={`tel:${phone.replace(/\s/g, '')}`}
                    class="block text-white text-sm hover:text-brand-200 transition-colors no-underline"
                  >
                    {phone}
                  </a>
                ))}
              </div>
            </div>

            <div class="w-full h-px bg-white/10"></div>

            <!-- Correu -->
            <div>
              <p class="text-brand-200 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">Correu electrònic</p>
              <a
                href={`mailto:${email}`}
                class="text-white text-sm hover:text-brand-200 transition-colors no-underline"
              >
                {email}
              </a>
            </div>

            <div class="w-full h-px bg-white/10"></div>

            <!-- Instagram -->
            <div>
              <p class="text-brand-200 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">Xarxes socials</p>
              <a
                href={instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-white text-sm hover:text-brand-200 transition-colors no-underline"
              >
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="2.25" y="2.25" width="19.5" height="19.5" rx="5.25" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="12" r="4.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="17.625" cy="6.375" r="0.75" fill="currentColor" stroke="none"/>
                </svg>
                @_abiotic_
              </a>
            </div>

          </div>

          <!-- Decorative large monogram at bottom -->
          <p class="font-display text-7xl font-medium text-white/5 leading-none select-none mt-12 text-right">Àb.</p>

        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<!-- Detect ?success=true after Netlify Forms redirect -->
<script>
  if (window.location.search.includes('success=true')) {
    document.getElementById('form-container')?.remove();
    document.getElementById('success-message')?.classList.remove('hidden');
  }
</script>
