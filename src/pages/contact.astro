---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import ContactDetail from '../components/ContactDetail.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'contact');
if (!entry) throw new Error('contact.md not found');

interface ContactData {
  intro: string;
  address: { street: string; city: string; country: string };
  phones: string[];
  email: string;
  instagram: string;
}

const { intro, address, phones, email, instagram } = entry.data as unknown as ContactData;
---

<BaseLayout title="Contacte — Àbiòtic">

  <PageHero title="Contacta'ns" subtitle={intro} />

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12">

        <!-- Form (3/5) -->
        <div class="md:col-span-3">
          <h2 class="text-xl font-semibold text-brand-700 mb-6">Envia'ns un missatge</h2>

          <!-- Success message (shown via JS when ?success=true) -->
          <div id="success-message" class="hidden rounded-lg bg-brand-50 border border-brand-100 p-8 text-center">
            <svg class="w-12 h-12 text-brand-500 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-lg font-semibold text-brand-700 mb-2">Missatge enviat!</h3>
            <p class="text-stone-600">Gràcies! Ens posarem en contacte aviat.</p>
          </div>

          <div id="form-container">
            <ContactForm netlifyFormName="contact" />
          </div>
        </div>

        <!-- Contact details (2/5) -->
        <div class="md:col-span-2">
          <h2 class="text-xl font-semibold text-brand-700 mb-6">Informació de contacte</h2>
          <div class="space-y-8">

            <ContactDetail label="Adreça">
              <svg slot="icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              {address.street}<br />{address.city}<br />{address.country}
            </ContactDetail>

            <ContactDetail label="Telèfon">
              <svg slot="icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              {phones.map((phone) => (
                <span class="block">
                  <a href={`tel:${phone.replace(/\s/g, '')}`} class="hover:text-brand-700 no-underline">{phone}</a>
                </span>
              ))}
            </ContactDetail>

            <ContactDetail label="Correu electrònic" href={`mailto:${email}`}>
              <svg slot="icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
              {email}
            </ContactDetail>

            <ContactDetail label="Xarxes socials" href={instagram} newTab={true}>
              <svg slot="icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
              </svg>
              Instagram — @_abiotic_
            </ContactDetail>

          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<!-- Detect ?success=true after Netlify Forms redirect -->
<script>
  if (window.location.search.includes('success=true')) {
    document.getElementById('form-container')?.remove();
    document.getElementById('success-message')?.classList.remove('hidden');
  }
</script>
