---
import CompanyTemplate from '../templates/CompanyTemplate.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'company');
if (!entry) throw new Error('company.md not found');
const { Content } = await render(entry);

interface AreaData { title: string; description: string; href: string; }
interface ValueData { title: string; description: string; }
interface CtaData { heading: string; label: string; href: string; }
interface PullquoteData { year: string; text: string; }
interface CompanyMdData {
  pullquote: PullquoteData;
  standards: string[];
  areas: AreaData[];
  values: ValueData[];
  cta: CtaData;
}

const raw = entry.data as unknown as CompanyMdData;
const data = {
  pullquote: raw.pullquote,
  standards: raw.standards,
  areas: raw.areas,
  values: raw.values,
  cta: raw.cta,
  bodyHtml: '', // prose slot is used below
};
---

<CompanyTemplate
  lang="ca"
  data={data}
  pageTitle="L'empresa — Àbiòtic"
  pageDescription="Coneix Àbiòtic, empresa de gestió ambiental fundada el 2019 a Andorra. Serveis ambientals i tècnics per a empreses i administracions."
>
  <Content slot="prose" />
</CompanyTemplate>
