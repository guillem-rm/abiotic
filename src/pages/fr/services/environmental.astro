---
import ServiceTemplate from '../../../templates/ServiceTemplate.astro';
import { servicesContent, getOtherServices } from '../../../i18n/translations';

const data = servicesContent['environmental'].fr;
const otherServices = getOtherServices('fr', 'environmental');
---

<ServiceTemplate
  lang="fr"
  serviceId="environmental"
  title={data.title}
  description={data.description}
  services={data.services}
  applications={data.applications}
  otherServices={otherServices}
>
  {data.body && <Fragment slot="body" set:html={data.body} />}
</ServiceTemplate>
