---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getEntry, getCollection } from 'astro:content';

const entry = await getEntry('services', 'water-management');
if (!entry) throw new Error('water-management.md not found');

const allServices = await getCollection('services');
const otherServices = allServices.filter((s) => s.id !== entry.id);
---

<BaseLayout title={`${entry.data.title} — Àbiòtic`} description={entry.data.description}>

  <PageHero
    title={entry.data.title}
    subtitle={entry.data.description}
    eyebrow="Serveis"
  />

  <!-- Main content -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

        <!-- Services list (8 cols) -->
        <div class="lg:col-span-8">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-8 h-px bg-brand-500"></div>
            <span class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em]">Àmbits d'actuació</span>
          </div>
          <ul class="space-y-0 divide-y divide-stone-100">
            {entry.data.services.map((item, i) => (
              <li class="flex items-start gap-6 py-5">
                <span class="font-display text-2xl font-medium text-stone-200 leading-none w-8 shrink-0 select-none mt-0.5">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-stone-700 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Applications panel (4 cols) -->
        <div class="lg:col-span-4">
          <div class="border border-stone-200 p-8">
            <!-- Top accent -->
            <div class="h-0.5 w-full bg-brand-500 -mt-8 -mx-8 mb-8 relative" style="width: calc(100% + 4rem);"></div>

            <p class="text-[10px] font-semibold text-stone-400 uppercase tracking-[0.2em] mb-5">Aplicacions</p>
            <div class="flex flex-wrap gap-2">
              {entry.data.applications.map((app) => (
                <span class="inline-flex items-center px-3 py-1.5 text-xs font-semibold bg-brand-50 text-brand-700 border border-brand-100">
                  {app}
                </span>
              ))}
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Altres serveis -->
  <section class="bg-stone-50 py-20 border-t border-stone-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading heading="Altres serveis" subheading="Explorar més àrees" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {otherServices.map((s) => (
          <ServiceCard
            title={s.data.title}
            description={s.data.description}
            href={`/services/${s.id}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Parlem del teu projecte" cta="Contacta'ns" href="/contact" />

</BaseLayout>
