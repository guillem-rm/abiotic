---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getEntry, getCollection } from 'astro:content';

const entry = await getEntry('services', 'engineering');
if (!entry) throw new Error('engineering.md not found');

const allServices = await getCollection('services');
const otherServices = allServices.filter((s) => s.id !== entry.id);
---

<BaseLayout title={`${entry.data.title} — Àbiòtic`}>

  <PageHero title={entry.data.title} subtitle={entry.data.description} />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

      <!-- Serveis -->
      <div>
        <h2 class="text-xl font-semibold text-brand-700 mb-6">Serveis</h2>
        <ul class="space-y-3">
          {entry.data.services.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-stone-700">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Aplicacions -->
      <div>
        <h2 class="text-xl font-semibold text-brand-700 mb-6">Aplicacions</h2>
        <div class="flex flex-wrap gap-2">
          {entry.data.applications.map((app) => (
            <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-brand-50 text-brand-700 border border-brand-100">
              {app}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Altres serveis -->
  <section class="bg-stone-50 py-16 border-t border-stone-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading heading="Altres serveis" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {otherServices.map((s) => (
          <ServiceCard
            title={s.data.title}
            description={s.data.description}
            href={`/services/${s.id}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Parlem del teu projecte" cta="Contacta'ns" href="/contact" />

</BaseLayout>
