---
import ServiceTemplate from '../../templates/ServiceTemplate.astro';
import { getEntry, getCollection, render } from 'astro:content';

const entry = await getEntry('services', 'environmental');
if (!entry) throw new Error('environmental.md not found');

const allServices = await getCollection('services');
const otherServices = allServices
  .filter((s) => s.id !== entry.id)
  .map((s) => ({ title: s.data.title, description: s.data.description, href: `/services/${s.id}` }));

const { Content } = await render(entry);
---

<ServiceTemplate
  lang="ca"
  serviceId="environmental"
  title={entry.data.title}
  description={entry.data.description}
  services={entry.data.services}
  applications={entry.data.applications}
  otherServices={otherServices}
>
  <Content slot="body" />
</ServiceTemplate>
