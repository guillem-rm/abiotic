---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const entry = await getEntry('pages', 'privacy');
if (!entry) throw new Error('privacy.md not found');
const { Content } = await render(entry);

const { pageTitle, pageDescription, heroSubtitle } = entry.data as {
  pageTitle: string;
  pageDescription: string;
  heroSubtitle: string;
};
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <PageHero
    title={entry.data.title as string}
    subtitle={heroSubtitle}
  />

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-stone max-w-none">
      <Content />
    </div>
  </section>

</BaseLayout>
