---
import { Image } from 'astro:assets';
import ambientalEdificiImg from '../assets/images/ambiental-edifici.png';
import oficinAbiotic from '../assets/images/oficina-abiotic.jpg';
import certificatIso14001 from '../assets/images/certificat-iso14001.png';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ValueItem from '../components/ValueItem.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import ProseContent from '../components/ProseContent.astro';
import { useTranslations } from '../i18n/utils';
import { type Locale, type CompanyData } from '../i18n/translations';

interface Props {
  lang: Locale;
  data: CompanyData;
  pageTitle: string;
  pageDescription: string;
}

const { lang, data, pageTitle, pageDescription } = Astro.props;
const { pullquote, standards, areas, values, cta, bodyHtml } = data;
const t = useTranslations(lang);
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- 1. Page hero -->
  <PageHero
    title={t('company.hero.title')}
    subtitle={t('company.hero.subtitle')}
    eyebrow={t('company.eyebrow')}
    image={ambientalEdificiImg}
    imageAlt="Edifici amb gestió ambiental a Andorra"
  />

  <!-- 2. Company introduction -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12" data-reveal>

        <!-- Prose body (2/3 width) -->
        <div class="md:col-span-2">
          <ProseContent>
            <slot name="prose">
              <div set:html={bodyHtml} />
            </slot>
          </ProseContent>

          <!-- Standards badges -->
          <div class="mt-6 flex flex-wrap gap-2">
            {standards.map((s) => (
              <span class="inline-flex items-center px-3 py-1.5 text-xs font-semibold bg-brand-50 text-brand-700 border border-brand-100">
                {s}
              </span>
            ))}
          </div>

          <!-- ISO certification badge -->
          <div class="mt-8 pt-6 border-t border-stone-100">
            <p class="text-[10px] font-semibold text-stone-500 uppercase tracking-[0.2em] mb-4">{t('company.certLabel')}</p>
            <Image
              src={certificatIso14001}
              alt="Certificació ISO 14001:2015 — IAS Accredited Management Systems Certification Body / G-CERT"
              class="h-16 w-auto"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Office photo + pull-quote (1/3 width) -->
        <div class="hidden md:block">
          <div class="sticky top-24 space-y-4">
            <div class="overflow-hidden border border-stone-200">
              <Image
                src={oficinAbiotic}
                alt="Seu d'Àbiòtic Gestió Ambiental a Andorra"
                class="w-full h-48 object-cover object-center"
                loading="lazy"
                widths={[400, 800]}
                sizes="(min-width: 768px) 33vw, 100vw"
              />
            </div>
            <div class="border border-stone-200 overflow-hidden">
              <div class="h-0.5 bg-secondary-500"></div>
              <div class="p-6">
                <p class="text-[10px] font-semibold text-brand-600 uppercase tracking-[0.2em] mb-3">
                  {t('company.foundedLabel')}
                </p>
                <p class="font-display text-4xl font-medium text-brand-700 mb-4">{pullquote.year}</p>
                <p class="text-sm text-stone-600 leading-relaxed">{pullquote.text}</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. Àrees d'activitat -->
  <section class="py-16 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading heading={t('company.areas.title')} />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal-stagger>

        <ServiceCard title={areas[0].title} description={areas[0].description} href={areas[0].href}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c0 0-6.75 7.313-6.75 11.25a6.75 6.75 0 0013.5 0C18.75 9.563 12 2.25 12 2.25z" />
          </svg>
        </ServiceCard>

        <ServiceCard title={areas[1].title} description={areas[1].description} href={areas[1].href}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 01-6.364-2.636C3.25 16.08 3 12 3 12s3.25.08 5.636 2.364A9 9 0 0012 21zm0 0a9 9 0 006.364-2.636C20.75 16.08 21 12 21 12s-3.25.08-5.636 2.364A9 9 0 0112 21zm0 0V9m0 0a3 3 0 100-6 3 3 0 000 6z" />
          </svg>
        </ServiceCard>

        <ServiceCard title={areas[2].title} description={areas[2].description} href={areas[2].href}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </ServiceCard>

      </div>
    </div>
  </section>

  <!-- 4. Valors -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading heading={t('company.values.title')} />
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8" data-reveal-stagger>

        <ValueItem title={values[0].title} description={values[0].description}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </ValueItem>

        <ValueItem title={values[1].title} description={values[1].description}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </ValueItem>

        <ValueItem title={values[2].title} description={values[2].description}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </ValueItem>

      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <CtaBand heading={cta.heading} cta={cta.label} href={cta.href} />

</BaseLayout>
