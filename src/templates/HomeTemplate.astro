---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaBand from '../components/CtaBand.astro';
import MarqueeBand from '../components/MarqueeBand.astro';
import { useTranslations, localePath } from '../i18n/utils';
import { type Locale, type HomeData } from '../i18n/translations';

interface Props {
  lang: Locale;
  data: HomeData;
  pageTitle: string;
  pageDescription: string;
}

const { lang, data, pageTitle, pageDescription } = Astro.props;
const { hero, services, mission, values, cta } = data;
const t = useTranslations(lang);
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- 1. Hero — dark full-bleed image -->
  <section class="relative overflow-hidden bg-brand-900 border-b border-brand-800 flex items-center" style="height: calc(100vh - 4rem); min-height: 580px;">
    <img
      src="/images/water-dam.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
      width="1600"
      height="900"
    />
    <div class="absolute inset-0" style="background: linear-gradient(108deg, rgba(5,61,80,0.97) 0%, rgba(5,61,80,0.93) 28%, rgba(5,61,80,0.68) 52%, rgba(5,61,80,0.22) 100%);"></div>
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.055) 1px, transparent 1px); background-size: 38px 38px;"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(to right, transparent, rgba(149,193,33,0.5), transparent);"></div>
    <div class="absolute bottom-8 left-0 right-0 flex flex-col items-center gap-1.5 animate-bounce" aria-hidden="true">
      <span class="text-white/40 text-[9px] uppercase tracking-[0.2em] font-semibold">Scroll</span>
      <svg class="w-5 h-5 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36 w-full">
      <div class="max-w-2xl">

        <div class="flex items-center gap-4 mb-10 animate-fade-up">
          <div class="w-8 h-px bg-secondary-500"></div>
          <span class="text-secondary-400 text-xs font-semibold uppercase tracking-[0.2em]">
            {t('home.hero.eyebrow')}
          </span>
        </div>

        <h1 class="mb-8 animate-fade-up delay-100">
          {hero.headline.map((line, i) => (
            <span class:list={[
              'block font-display leading-[1.1]',
              i === 0 ? 'text-5xl sm:text-6xl lg:text-7xl font-medium text-white' :
              i === 1 ? 'text-4xl sm:text-5xl lg:text-6xl font-normal italic text-secondary-400 mt-1' :
                        'text-3xl sm:text-4xl lg:text-5xl font-normal text-brand-200 mt-2'
            ]}>{line}</span>
          ))}
        </h1>

        <p class="text-brand-100/85 text-lg leading-relaxed mb-10 max-w-md animate-fade-up delay-200">{hero.tagline}</p>

        <div class="flex flex-wrap gap-4 animate-fade-up delay-300">
          <a
            href="#serveis"
            class="inline-flex items-center gap-2.5 bg-secondary-500 text-brand-900 text-xs font-semibold px-7 py-4 hover:bg-secondary-400 no-underline uppercase tracking-widest btn-press"
          >
            {t('home.hero.cta.services')}
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={localePath(lang, '/contact')}
            class="inline-flex items-center gap-2 border border-white/25 text-white text-xs font-semibold px-7 py-4 hover:border-white/50 hover:bg-white/8 no-underline uppercase tracking-widest btn-press"
          >
            {t('home.hero.cta.contact')}
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="relative bg-brand-700 overflow-hidden" data-reveal>
    <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 32px 32px;"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
        <div class="py-9 px-6 text-center">
          <p class="font-display text-4xl font-medium text-white tracking-tight">2019</p>
          <p class="text-secondary-400 text-[9px] uppercase tracking-[0.2em] mt-2">{t('home.stats.founded')}</p>
        </div>
        <div class="py-9 px-6 text-center">
          <p class="font-display text-4xl font-medium text-white tracking-tight">3</p>
          <p class="text-secondary-400 text-[9px] uppercase tracking-[0.2em] mt-2">{t('home.stats.areas')}</p>
        </div>
        <div class="py-9 px-6 text-center">
          <p class="font-display text-4xl font-medium text-white tracking-tight">AND</p>
          <p class="text-secondary-400 text-[9px] uppercase tracking-[0.2em] mt-2">{t('home.stats.presence')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Serveis principals -->
  <section id="serveis" class="py-24 bg-stone-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between pb-8 mb-10 border-b border-stone-200">
        <h2 class="font-display text-3xl font-medium text-stone-900">{t('home.services.title')}</h2>
        <p class="text-stone-400 text-sm hidden sm:block">{t('home.services.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal-stagger>

        <ServiceCard title={services[0].title} description={services[0].description} href={services[0].href}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c0 0-6.75 7.313-6.75 11.25a6.75 6.75 0 0013.5 0C18.75 9.563 12 2.25 12 2.25z" />
          </svg>
        </ServiceCard>

        <ServiceCard title={services[1].title} description={services[1].description} href={services[1].href}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 01-6.364-2.636C3.25 16.08 3 12 3 12s3.25.08 5.636 2.364A9 9 0 0012 21zm0 0a9 9 0 006.364-2.636C20.75 16.08 21 12 21 12s-3.25.08-5.636 2.364A9 9 0 0112 21zm0 0V9m0 0a3 3 0 100-6 3 3 0 000 6z" />
          </svg>
        </ServiceCard>

        <ServiceCard title={services[2].title} description={services[2].description} href={services[2].href}>
          <svg slot="icon" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </ServiceCard>

      </div>
    </div>
  </section>

  <!-- 3. Missió -->
  <section class="py-24 bg-white border-t border-stone-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center" data-reveal>

        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-8 h-px bg-secondary-500"></div>
            <span class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em]">{t('home.mission.label')}</span>
          </div>
          <h2 class="font-display text-4xl font-medium text-stone-900 leading-[1.2] mb-6">{mission.heading}</h2>
          <p class="text-stone-600 leading-relaxed mb-4">{mission.body}</p>
          <p class="text-stone-500 leading-relaxed text-sm">{mission.visio}</p>
        </div>

        <div class="hidden lg:block">
          <div class="relative pb-3 pr-3">
            <div class="relative border border-stone-200 p-10 bg-stone-50 overflow-hidden">
              <span class="font-display text-9xl text-brand-100 leading-none absolute -top-2 left-6 select-none">"</span>
              <blockquote class="font-display text-xl font-normal italic text-stone-700 leading-relaxed relative z-10 mt-6">
                {t('home.mission.quote')}
              </blockquote>
              <div class="mt-8 pt-6 border-t border-stone-200">
                <div class="grid grid-cols-2 gap-6">
                  <div>
                    <p class="font-display text-2xl font-medium text-brand-700">ISO</p>
                    <p class="text-[10px] text-stone-400 mt-1 uppercase tracking-widest">14001 · EMAS</p>
                  </div>
                  <div>
                    <p class="font-display text-2xl font-medium text-brand-700">5+</p>
                    <p class="text-[10px] text-stone-400 mt-1 uppercase tracking-widest">{t('home.mission.years')}</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute inset-0 border border-brand-200 translate-x-3 translate-y-3 -z-10"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Marquee band -->
  <MarqueeBand text={t('marquee.text')} />

  <!-- 4. Valors -->
  <section class="py-24 bg-stone-50 border-t border-stone-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-baseline justify-between pb-8 mb-10 border-b border-stone-200">
        <h2 class="font-display text-3xl font-medium text-stone-900">{t('home.values.title')}</h2>
        <p class="text-stone-400 text-sm hidden sm:block">{t('home.values.subtitle')}</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-stone-200" data-reveal-stagger>

        <div class="py-8 sm:pr-10">
          <span class="font-display text-6xl font-medium text-stone-100 leading-none block select-none">01</span>
          <h3 class="text-sm font-semibold text-brand-700 mt-3 mb-2 uppercase tracking-wide">{values[0].title}</h3>
          <p class="text-sm text-stone-600 leading-relaxed">{values[0].description}</p>
        </div>

        <div class="py-8 sm:px-10">
          <span class="font-display text-6xl font-medium text-stone-100 leading-none block select-none">02</span>
          <h3 class="text-sm font-semibold text-brand-700 mt-3 mb-2 uppercase tracking-wide">{values[1].title}</h3>
          <p class="text-sm text-stone-600 leading-relaxed">{values[1].description}</p>
        </div>

        <div class="py-8 sm:pl-10">
          <span class="font-display text-6xl font-medium text-stone-100 leading-none block select-none">03</span>
          <h3 class="text-sm font-semibold text-brand-700 mt-3 mb-2 uppercase tracking-wide">{values[2].title}</h3>
          <p class="text-sm text-stone-600 leading-relaxed">{values[2].description}</p>
        </div>

      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <CtaBand heading={cta.heading} cta={cta.label} href={cta.href} />

</BaseLayout>
