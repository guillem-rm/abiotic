---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import { useTranslations, localePath } from '../i18n/utils';
import { type Locale, type ContactData } from '../i18n/translations';

interface Props {
  lang: Locale;
  data: ContactData;
  pageTitle: string;
  pageDescription: string;
}

const { lang, data, pageTitle, pageDescription } = Astro.props;
const { intro, address, phones, email, instagram } = data;
const t = useTranslations(lang);
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <PageHero
    title={t('contact.hero.title')}
    subtitle={intro}
    eyebrow={t('contact.eyebrow')}
  />

  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 lg:gap-0 border border-stone-200" data-reveal>

        <!-- Form (7 cols) -->
        <div class="lg:col-span-7 p-8 lg:p-12 border-b lg:border-b-0 lg:border-r border-stone-200">

          <div class="flex items-baseline justify-between pb-7 mb-10 border-b border-stone-200">
            <h2 class="font-display text-2xl font-medium text-stone-900">{t('contact.form.title')}</h2>
          </div>

          <!-- Success message -->
          <div id="success-message" class="hidden border-l-2 border-brand-500 bg-brand-50 px-8 py-10">
            <p class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em] mb-3">{t('contact.success.label')}</p>
            <p class="font-display text-2xl font-medium text-stone-900 mb-2">{t('contact.success.title')}</p>
            <p class="text-stone-500 text-sm leading-relaxed">{t('contact.success.body')}</p>
          </div>

          <div id="form-container">
            <ContactForm netlifyFormName="contact" lang={lang} privacyHref={localePath(lang, '/privacy')} />
          </div>
        </div>

        <!-- Contact info panel (5 cols) -->
        <div class="lg:col-span-5 bg-brand-700 p-8 lg:p-12 flex flex-col">

          <div class="pb-7 mb-10 border-b border-white/10">
            <h2 class="font-display text-xl font-medium text-white">{t('contact.info.title')}</h2>
          </div>

          <div class="space-y-8 flex-1">

            <div>
              <p class="text-brand-100 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">{t('contact.info.address')}</p>
              <p class="text-white text-sm leading-relaxed">
                {address.street}<br />
                {address.city}<br />
                {address.country}
              </p>
            </div>

            <div class="w-full h-px bg-white/10"></div>

            <div>
              <p class="text-brand-100 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">{t('contact.info.phone')}</p>
              <div class="space-y-1">
                {phones.map((phone) => (
                  <a
                    href={`tel:${phone.replace(/\s/g, '')}`}
                    class="block text-white text-sm hover:text-brand-200 transition-colors no-underline"
                  >
                    {phone}
                  </a>
                ))}
              </div>
            </div>

            <div class="w-full h-px bg-white/10"></div>

            <div>
              <p class="text-brand-100 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">{t('contact.info.email')}</p>
              <a
                href={`mailto:${email}`}
                class="text-white text-sm hover:text-brand-200 transition-colors no-underline"
              >
                {email}
              </a>
            </div>

            <div class="w-full h-px bg-white/10"></div>

            <div>
              <p class="text-brand-100 text-[10px] font-semibold uppercase tracking-[0.2em] mb-2">{t('contact.info.social')}</p>
              <a
                href={instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-white text-sm hover:text-brand-200 transition-colors no-underline"
              >
                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <rect x="2.25" y="2.25" width="19.5" height="19.5" rx="5.25" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="12" r="4.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="17.625" cy="6.375" r="0.75" fill="currentColor" stroke="none"/>
                </svg>
                @_abiotic_
              </a>
            </div>

          </div>

          <p class="font-display text-7xl font-medium text-white/5 leading-none select-none mt-12 text-right" aria-hidden="true">Àb.</p>

        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<script>
  if (window.location.search.includes('success=true')) {
    document.getElementById('form-container')?.remove();
    document.getElementById('success-message')?.classList.remove('hidden');
  }
</script>
