---
import { Image } from 'astro:assets';
import waterCentralImg from '../assets/images/water-central.png';
import waterSalaBombesImg from '../assets/images/water-sala-bombes.png';
import ambientalEdificiImg from '../assets/images/ambiental-edifici.png';
import enginyeriaCalderaImg from '../assets/images/enginyeria-caldera.png';
import waterValveDetailImg from '../assets/images/water-valve-detail.png';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceBodyContent from '../components/ServiceBodyContent.astro';
import { useTranslations, localePath } from '../i18n/utils';
import { type Locale } from '../i18n/translations';

interface OtherService {
  title: string;
  description: string;
  href: string;
}

interface Props {
  lang: Locale;
  serviceId: 'water-management' | 'environmental' | 'engineering';
  title: string;
  description: string;
  services: string[];
  applications: string[];
  otherServices: OtherService[];
}

const { lang, serviceId, title, description, services, applications, otherServices } = Astro.props;
const t = useTranslations(lang);

// Per-service image and badge config
const serviceConfig = {
  'water-management': {
    heroImage: waterCentralImg,
    heroImageAlt: 'Central hídrica al Principat d\'Andorra',
    sideImage: waterSalaBombesImg,
    sideImageAlt: 'Sala de bombes i instal·lacions hídriques',
    badge: null,
  },
  'environmental': {
    heroImage: ambientalEdificiImg,
    heroImageAlt: 'Edifici sostenible envoltat de vegetació',
    sideImage: ambientalEdificiImg,
    sideImageAlt: 'Consultoria ambiental — edifici sostenible',
    badge: null,
  },
  'engineering': {
    heroImage: enginyeriaCalderaImg,
    heroImageAlt: 'Instal·lació de calderes de biomassa',
    sideImage: waterValveDetailImg,
    sideImageAlt: 'Detall de vàlvula d\'instal·lació hídrica',
    badge: null,
  },
};

const config = serviceConfig[serviceId];

---

<BaseLayout title={`${title} — Àbiòtic`} description={description}>

  <PageHero
    title={title}
    subtitle={description}
    eyebrow={t('services.eyebrow')}
    image={config.heroImage}
    imageAlt={config.heroImageAlt}
  />

  <!-- Main content -->
  <section class="bg-white">
    <!-- Mobile image -->
    <div class="overflow-hidden lg:hidden">
      <Image
        src={config.sideImage}
        alt={config.sideImageAlt}
        class="w-full h-[240px] sm:h-[300px] object-cover service-img-zoom"
        loading="lazy"
        widths={[640, 1024]}
        sizes="100vw"
      />
    </div>

    <!-- Split layout -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 lg:items-stretch" data-reveal>

        <!-- Content: left 7 cols -->
        <div class="lg:col-span-7 py-16 lg:py-20 lg:pr-14">

          <!-- Services list -->
          <div class="flex items-center gap-4 mb-8">
            <div class="w-8 h-px bg-brand-500"></div>
            <span class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em]">{t('services.areas')}</span>
          </div>
          <ul class="space-y-0 divide-y divide-stone-100 mb-10">
            {services.map((item, i) => (
              <li class="flex items-start gap-6 py-5">
                <span class="font-display text-2xl font-medium text-stone-500 leading-none w-8 shrink-0 select-none mt-0.5">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-stone-700 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>

          <!-- Applications panel -->
          <div class="border border-stone-200 p-8">
            <div class="h-0.5 w-full bg-secondary-500 -mt-8 -mx-8 mb-8 relative" style="width: calc(100% + 4rem);"></div>
            <p class="text-[10px] font-semibold text-stone-500 uppercase tracking-[0.2em] mb-5">{t('services.applications')}</p>
            <div class="flex flex-wrap gap-2">
              {applications.map((app) => (
                <span class="inline-flex items-center px-3 py-1.5 text-xs font-semibold bg-brand-50 text-brand-700 border border-brand-100">
                  {app}
                </span>
              ))}
            </div>
          </div>

        </div>

        <!-- Image: right 5 cols, fills full height -->
        <div class="hidden lg:block lg:col-span-5 relative overflow-hidden min-h-[500px]">
          <Image
            src={config.sideImage}
            alt={config.sideImageAlt}
            class="absolute inset-0 w-full h-full object-cover service-img-zoom"
            loading="lazy"
            widths={[600, 900]}
            sizes="(min-width: 1024px) 40vw, 100vw"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Rich body content (optional) -->
  {Astro.slots.has('body') && (
    <section class="bg-white border-t border-stone-100">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
        <ServiceBodyContent>
          <slot name="body" />
        </ServiceBodyContent>
      </div>
    </section>
  )}

  <!-- Other services -->
  <section class="bg-stone-50 py-20 border-t border-stone-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading heading={t('services.other')} subheading={t('services.otherSub')} />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-reveal-stagger>
        {otherServices.map((s) => (
          <ServiceCard
            title={s.title}
            description={s.description}
            href={s.href}
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading={t('services.cta.heading')} cta={t('nav.contact')} href={localePath(lang, '/contact')} />

</BaseLayout>
