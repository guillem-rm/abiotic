---
import { Font } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getLangFromUrl, getLocaleUrl } from '../i18n/utils';
import { locales, ogLocales, type Locale } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Àbiòtic — Consultoria Ambiental Andorra',
  description,
  ogImage = '/og-image.svg',
} = Astro.props;

const lang: Locale = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const ogImageURL = new URL(ogImage, Astro.site ?? Astro.url.origin).toString();

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Àbiòtic',
  url: 'https://abiotic.ad',
  logo: 'https://abiotic.ad/images/favicon.png',
  image: 'https://abiotic.ad/og-image.svg',
  description: 'Consultoria ambiental i gestió de recursos hídrics a Andorra.',
  telephone: ['+376877770', '+376677588'],
  email: 'abiotic.and@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Sant Joan de Caselles, Edifici Vilaedra nº75',
    addressLocality: 'Canillo',
    postalCode: 'AD100',
    addressCountry: 'AD',
  },
  sameAs: ['https://www.instagram.com/_abiotic_/'],
  areaServed: {
    '@type': 'Country',
    name: 'Andorra',
  },
};

// Build hreflang alternate URLs for SEO
const alternates = locales.map((locale) => ({
  locale,
  url: new URL(getLocaleUrl(locale, Astro.url.pathname), Astro.site ?? Astro.url.origin).toString(),
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates -->
    {alternates.map(({ locale, url }) => (
      <link rel="alternate" hreflang={locale} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(getLocaleUrl('ca', Astro.url.pathname), Astro.site ?? Astro.url.origin).toString()} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={ogLocales[lang]} />
    <meta property="og:site_name" content="Àbiòtic" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Font preloads -->
    <Font cssVariable="--font-lora" preload={true} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon.png" />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Skip to main content — keyboard/screen reader accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-secondary-500 focus:text-brand-900 focus:text-xs focus:font-semibold focus:uppercase focus:tracking-widest focus:no-underline"
    >
      Salta al contingut principal
    </a>
    <Header lang={lang} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- Scroll-reveal observer -->
    <script>
      const reveals = document.querySelectorAll('[data-reveal], [data-reveal-stagger]');
      if (reveals.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );
        reveals.forEach((el) => observer.observe(el));
      }
    </script>
  </body>
</html>
