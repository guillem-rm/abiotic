---
import { useTranslations } from '../i18n/utils';
import { type Locale } from '../i18n/translations';

interface Props {
  netlifyFormName?: string;
  lang?: Locale;
  privacyHref?: string;
}

const { netlifyFormName = 'contact', lang = 'ca', privacyHref = '/privacy' } = Astro.props;
const t = useTranslations(lang);
---

<form
  name={netlifyFormName}
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-8"
  id="contact-form"
>
  <input type="hidden" name="form-name" value={netlifyFormName} />

  <!-- Honeypot (hidden from humans) -->
  <div class="hidden" aria-hidden="true">
    <label>No omplis aquest camp: <input name="bot-field" /></label>
  </div>

  <!-- Name -->
  <div class="group">
    <label for="name" class="block text-xs font-semibold text-stone-500 uppercase tracking-[0.2em] mb-3">
      {t('form.name')} <span class="text-brand-500">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-3 py-3 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors"
      placeholder="Joan Garcia"
    />
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="block text-xs font-semibold text-stone-500 uppercase tracking-[0.2em] mb-3">
      {t('form.email')} <span class="text-brand-500">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-3 py-3 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors"
      placeholder="joan@empresa.com"
    />
  </div>

  <!-- Company -->
  <div>
    <label for="company" class="block text-xs font-semibold text-stone-500 uppercase tracking-[0.2em] mb-3">
      {t('form.company')} <span class="text-stone-500 font-normal normal-case tracking-normal">{t('form.company.optional')}</span>
    </label>
    <input
      type="text"
      id="company"
      name="company"
      autocomplete="organization"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-3 py-3 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors"
      placeholder={t('form.company.placeholder')}
    />
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-xs font-semibold text-stone-500 uppercase tracking-[0.2em] mb-3">
      {t('form.message')} <span class="text-brand-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-3 py-3 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors resize-none"
      placeholder={t('form.message.placeholder')}
    ></textarea>
  </div>

  <!-- Privacy -->
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="privacy"
      name="privacy"
      required
      class="mt-0.5 h-4 w-4 rounded-none border-stone-300 text-brand-700 focus:ring-brand-500 cursor-pointer"
    />
    <label for="privacy" class="text-xs text-stone-500 cursor-pointer leading-relaxed">
      {t('form.privacy')}
      <a href={privacyHref} class="text-brand-600 hover:text-brand-800 underline underline-offset-2">{t('form.privacy.link')}</a>.
    </label>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <button
      type="submit"
      id="submit-btn"
      class="inline-flex items-center gap-2.5 bg-secondary-500 text-brand-900 text-xs font-semibold px-7 py-4 hover:bg-secondary-400 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary-500 focus-visible:ring-offset-2 uppercase tracking-widest disabled:opacity-60 disabled:cursor-not-allowed"
    >
      <span id="submit-label">{t('form.submit')}</span>
      <svg id="submit-arrow" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
      <svg id="submit-spinner" class="hidden w-3.5 h-3.5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
      </svg>
    </button>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const label = document.getElementById('submit-label');
  const arrow = document.getElementById('submit-arrow');
  const spinner = document.getElementById('submit-spinner');

  form?.addEventListener('submit', () => {
    if (!btn || !label || !arrow || !spinner) return;
    btn.disabled = true;
    label.textContent = '…';
    arrow.classList.add('hidden');
    spinner.classList.remove('hidden');
  });
</script>
