---
interface Props {
  netlifyFormName?: string;
}

const { netlifyFormName = 'contact' } = Astro.props;
---

<form
  name={netlifyFormName}
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-8"
  id="contact-form"
>
  <input type="hidden" name="form-name" value={netlifyFormName} />

  <!-- Honeypot (hidden from humans) -->
  <div class="hidden" aria-hidden="true">
    <label>No omplis aquest camp: <input name="bot-field" /></label>
  </div>

  <!-- Nom i cognoms -->
  <div class="group">
    <label for="name" class="block text-[10px] font-semibold text-stone-400 uppercase tracking-[0.2em] mb-3">
      Nom i cognoms <span class="text-brand-500">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      autocomplete="name"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-0 py-2.5 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors"
      placeholder="Joan Garcia"
    />
  </div>

  <!-- Correu electrònic -->
  <div>
    <label for="email" class="block text-[10px] font-semibold text-stone-400 uppercase tracking-[0.2em] mb-3">
      Correu electrònic <span class="text-brand-500">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      autocomplete="email"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-0 py-2.5 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors"
      placeholder="joan@empresa.com"
    />
  </div>

  <!-- Empresa -->
  <div>
    <label for="company" class="block text-[10px] font-semibold text-stone-400 uppercase tracking-[0.2em] mb-3">
      Empresa <span class="text-stone-300 font-normal normal-case tracking-normal">(opcional)</span>
    </label>
    <input
      type="text"
      id="company"
      name="company"
      autocomplete="organization"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-0 py-2.5 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors"
      placeholder="Nom de l'empresa"
    />
  </div>

  <!-- Missatge -->
  <div>
    <label for="message" class="block text-[10px] font-semibold text-stone-400 uppercase tracking-[0.2em] mb-3">
      Missatge <span class="text-brand-500">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full border-0 border-b border-stone-200 bg-transparent px-0 py-2.5 text-sm text-stone-800 placeholder-stone-300 focus:outline-none focus-visible:outline-none focus:border-brand-500 focus-visible:ring-1 focus-visible:ring-brand-500 focus-visible:ring-offset-0 focus:ring-0 transition-colors resize-none"
      placeholder="Explica'ns en què podem ajudar-te..."
    ></textarea>
  </div>

  <!-- Política de privadesa -->
  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="privacy"
      name="privacy"
      required
      class="mt-0.5 h-4 w-4 rounded-none border-stone-300 text-brand-700 focus:ring-brand-500 cursor-pointer"
    />
    <label for="privacy" class="text-xs text-stone-500 cursor-pointer leading-relaxed">
      He llegit i accepto la
      <a href="/privacy" class="text-brand-600 hover:text-brand-800 underline underline-offset-2">política de privadesa</a>.
    </label>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <button
      type="submit"
      class="inline-flex items-center gap-2.5 bg-secondary-500 text-brand-900 text-xs font-semibold px-7 py-4 hover:bg-secondary-600 transition-colors focus:outline-none focus:ring-2 focus:ring-secondary-500 focus:ring-offset-2 uppercase tracking-widest"
    >
      Envia el missatge
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </button>
  </div>
</form>
