---
interface Props {
  heading: string;
  subheading?: string;
  centered?: boolean;
}

const { heading, subheading, centered = false } = Astro.props;
---

<div class:list={['mb-10', centered ? 'text-center' : '']}>
  <h2 class="text-2xl sm:text-3xl font-semibold text-brand-700">{heading}</h2>
  {subheading && (
    <p class="mt-3 text-stone-500 text-base max-w-2xl" class:list={[centered ? 'mx-auto' : '']}>
      {subheading}
    </p>
  )}
</div>
