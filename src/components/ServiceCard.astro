---
interface Props {
  title: string;
  description: string;
  href: string;
  cta?: string;
}

const { title, description, href, cta = 'Veure servei' } = Astro.props;
---

<a
  href={href}
  class="group block bg-white border border-stone-200 overflow-hidden no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 service-card-hover"
>
  <!-- Top accent bar — scaleY transform (no layout reflow) -->
  <div class="service-card-bar bg-secondary-500 w-full"></div>

  <div class="p-7">
    <!-- Icon slot -->
    <div class="mb-5 text-brand-400 group-hover:text-brand-600 service-card-icon">
      <slot name="icon">
        <div class="w-10 h-10 bg-brand-50 flex items-center justify-center">
          <div class="w-4 h-4 bg-brand-500"></div>
        </div>
      </slot>
    </div>

    <h3 class="font-display text-lg font-medium text-stone-900 mb-2 group-hover:text-brand-700 transition-colors duration-200">
      {title}
    </h3>
    <p class="text-sm text-stone-500 leading-relaxed">
      {description}
    </p>
    <span class="inline-flex items-center gap-1.5 mt-6 text-[11px] font-semibold uppercase tracking-widest text-brand-500 group-hover:text-brand-700 transition-colors duration-200">
      {cta}
      <svg class="service-card-arrow w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
