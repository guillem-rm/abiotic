---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<a
  href={href}
  class="group block bg-white border border-stone-200 rounded-lg overflow-hidden hover:border-brand-300 hover:shadow-md transition-all no-underline"
>
  <!-- Brand accent bar -->
  <div class="h-1 bg-brand-500 group-hover:bg-brand-700 transition-colors"></div>

  <div class="p-6">
    <!-- Icon slot -->
    <div class="mb-4 text-brand-500 group-hover:text-brand-700 transition-colors">
      <slot name="icon">
        <!-- Default placeholder icon -->
        <div class="w-10 h-10 rounded-full bg-brand-50 flex items-center justify-center">
          <div class="w-4 h-4 rounded-full bg-brand-500"></div>
        </div>
      </slot>
    </div>

    <h3 class="text-lg font-semibold text-brand-700 mb-2 group-hover:text-brand-500 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-stone-600 leading-relaxed">
      {description}
    </p>
    <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-brand-500 group-hover:text-brand-700 transition-colors">
      Veure servei
      <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
