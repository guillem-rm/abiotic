---
const year = new Date().getFullYear();

const serviceLinks = [
  { href: '/services/water-management', label: "Gestió d'Aigua" },
  { href: '/services/environmental', label: 'Gestió Ambiental' },
  { href: '/services/engineering', label: 'Enginyeria' },
];
---

<footer class="bg-stone-50 border-t border-stone-200 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Column 1: Brand -->
      <div>
        <a href="/" class="text-lg font-semibold text-brand-700 hover:text-brand-500 no-underline">Àbiòtic</a>
        <p class="mt-2 text-sm text-stone-500 leading-relaxed">
          Consultoria ambiental i gestió de recursos hídrics a Andorra.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h3 class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-4">Navegació</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-stone-600 hover:text-brand-700 no-underline">Inici</a></li>
          <li><a href="/company" class="text-stone-600 hover:text-brand-700 no-underline">L'empresa</a></li>
          {serviceLinks.map(({ href, label }) => (
            <li><a href={href} class="text-stone-600 hover:text-brand-700 no-underline">{label}</a></li>
          ))}
          <li><a href="/contact" class="text-stone-600 hover:text-brand-700 no-underline">Contacte</a></li>
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-4">Contacte</h3>
        <address class="not-italic text-sm text-stone-600 space-y-2">
          <p class="leading-relaxed">
            Sant Joan de Caselles, Edifici Vilaedra nº75<br />
            AD100 Canillo, Principat d'Andorra
          </p>
          <p>
            <a href="tel:+376877770" class="hover:text-brand-700 no-underline">+376 877 770</a><br />
            <a href="tel:+376677588" class="hover:text-brand-700 no-underline">+376 677 588</a>
          </p>
          <p>
            <a href="mailto:abiotic.and@gmail.com" class="hover:text-brand-700 no-underline">abiotic.and@gmail.com</a>
          </p>
          <p>
            <a href="https://www.instagram.com/_abiotic_/" target="_blank" rel="noopener noreferrer" class="hover:text-brand-700 no-underline">
              Instagram
            </a>
          </p>
        </address>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-stone-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <p class="text-xs text-stone-400 text-center">
        &copy; {year} Àbiòtic. Tots els drets reservats. ·
        <a href="/privacy" class="hover:text-stone-600 no-underline">Política de Privacitat</a>
      </p>
    </div>
  </div>
</footer>
