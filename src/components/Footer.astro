---
const year = new Date().getFullYear();

const serviceLinks = [
  { href: '/services/water-management', label: "Gestió d'Aigua" },
  { href: '/services/environmental', label: 'Gestió Ambiental' },
  { href: '/services/engineering', label: 'Enginyeria' },
];
---

<footer class="bg-brand-900 border-t border-brand-800 mt-auto">
  <!-- Top accent shimmer -->
  <div class="h-px" style="background: linear-gradient(to right, transparent, rgba(149,193,33,0.6), transparent);"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Column 1: Brand -->
      <div>
        <a href="/" class="no-underline inline-block group" aria-label="Àbiòtic — Inici">
          <span class="font-display text-2xl italic font-medium text-white group-hover:text-brand-200 transition-colors">Àbiòtic</span>
        </a>
        <p class="mt-3 text-sm text-brand-300/70 leading-relaxed">
          Consultoria ambiental i gestió de recursos hídrics a Andorra.
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <h3 class="text-[10px] font-semibold text-secondary-500 uppercase tracking-[0.2em] mb-4">Navegació</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-brand-300/80 hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">Inici</a></li>
          <li><a href="/company" class="text-brand-300/80 hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">L'empresa</a></li>
          {serviceLinks.map(({ href, label }) => (
            <li><a href={href} class="text-brand-300/80 hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">{label}</a></li>
          ))}
          <li><a href="/contact" class="text-brand-300/80 hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">Contacte</a></li>
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div>
        <h3 class="text-[10px] font-semibold text-secondary-500 uppercase tracking-[0.2em] mb-4">Contacte</h3>
        <address class="not-italic text-sm text-brand-300/80 space-y-2">
          <p class="leading-relaxed">
            Sant Joan de Caselles, Edifici Vilaedra nº75<br />
            AD100 Canillo, Principat d'Andorra
          </p>
          <p>
            <a href="tel:+376877770" class="hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">+376 877 770</a><br />
            <a href="tel:+376677588" class="hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">+376 677 588</a>
          </p>
          <p>
            <a href="mailto:abiotic.and@gmail.com" class="hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">abiotic.and@gmail.com</a>
          </p>
          <p>
            <a href="https://www.instagram.com/_abiotic_/" target="_blank" rel="noopener noreferrer" class="hover:text-white no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-brand-300 focus-visible:ring-offset-2 focus-visible:ring-offset-brand-900">
              Instagram
            </a>
          </p>
        </address>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-brand-800/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <p class="text-xs text-brand-500 text-center">
        &copy; {year} Àbiòtic. Tots els drets reservats. ·
        <a href="/privacy" class="hover:text-brand-300 no-underline transition-colors">Política de Privacitat</a>
      </p>
    </div>
  </div>
</footer>
