---
const text = 'El potencial de les energies renovables és immens';
---

<section class="marquee-band overflow-hidden bg-brand-900 pt-6 pb-10 border-t border-b border-brand-800 select-none" aria-hidden="true">

  <!-- Fila 1: cap a l'esquerra — text outline blanc -->
  <div class="marquee-track marquee-left flex whitespace-nowrap mb-2">
    <span class="inline-flex items-center gap-16 pr-16">
      <span class="text-outline font-display text-7xl sm:text-8xl lg:text-9xl font-medium tracking-tight leading-none">{text}</span>
      <span class="w-3 h-3 rounded-full bg-white/30 flex-shrink-0"></span>
    </span>
    <span class="inline-flex items-center gap-16 pr-16">
      <span class="text-outline font-display text-7xl sm:text-8xl lg:text-9xl font-medium tracking-tight leading-none">{text}</span>
      <span class="w-3 h-3 rounded-full bg-white/30 flex-shrink-0"></span>
    </span>
  </div>

  <!-- Fila 2: cap a la dreta — text italica verd -->
  <div class="marquee-track marquee-right flex whitespace-nowrap">
    <span class="inline-flex items-center gap-16 pr-16">
      <span class="font-display text-7xl sm:text-8xl lg:text-9xl font-medium text-secondary-400/50 tracking-tight italic leading-none">{text}</span>
      <span class="w-3 h-3 rounded-full bg-secondary-500/25 flex-shrink-0"></span>
    </span>
    <span class="inline-flex items-center gap-16 pr-16">
      <span class="font-display text-7xl sm:text-8xl lg:text-9xl font-medium text-secondary-400/50 tracking-tight italic leading-none">{text}</span>
      <span class="w-3 h-3 rounded-full bg-secondary-500/25 flex-shrink-0"></span>
    </span>
  </div>

</section>

<style>
  .text-outline {
    color: transparent;
    -webkit-text-stroke: 1px white;
  }

  .marquee-left {
    width: max-content;
    will-change: transform;
    animation: marquee-left 20s linear infinite;
  }

  .marquee-right {
    width: max-content;
    will-change: transform;
    animation: marquee-right 20s linear infinite;
  }

  .marquee-left:hover,
  .marquee-right:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-left,
    .marquee-right {
      animation: none;
    }
  }
</style>
