---
import { Image } from 'astro:assets';
import logoImg from '../assets/images/logo.png';
import { useTranslations, getLocaleUrl, localePath } from '../i18n/utils';
import { locales, languageNames, languageFlagImg, type Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const pathname = Astro.url.pathname;

const serviceLinks = [
  { href: localePath(lang, '/services/water-management'), label: t('nav.services.water') },
  { href: localePath(lang, '/services/environmental'), label: t('nav.services.environmental') },
  { href: localePath(lang, '/services/engineering'), label: t('nav.services.engineering') },
];

const isServicesActive = pathname.includes('/services');

function isActive(href: string): boolean {
  if (href === '/' || href === `/${lang}`) {
    return pathname === '/' || pathname === `/${lang}` || pathname === `/${lang}/`;
  }
  return pathname.startsWith(href);
}
---

<header class="bg-white border-b border-stone-200 sticky top-0 z-50">
  <!-- Checkbox must be a sibling of the mobile panel for Tailwind peer to work -->
  <input type="checkbox" id="mobile-menu" class="sr-only peer/menu" aria-hidden="true" tabindex="-1" />
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={localePath(lang, '/')} class="no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2" aria-label="Àbiòtic — Inici">
        <Image src={logoImg} alt="Àbiòtic Gestió Ambiental" class="h-9 w-auto" fetchpriority="high" widths={[151, 302]} sizes="151px" quality={85} />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-7">

        <a
          href={localePath(lang, '/')}
          class:list={[
            'text-[11px] font-semibold uppercase tracking-widest no-underline transition-colors pt-2 pb-1',
            isActive(localePath(lang, '/'))
              ? 'text-brand-700 border-b border-secondary-500'
              : 'text-stone-500 hover:text-brand-700 border-b border-transparent hover:border-secondary-300'
          ]}
        >
          {t('nav.home')}
        </a>

        <a
          href={localePath(lang, '/company')}
          class:list={[
            'text-[11px] font-semibold uppercase tracking-widest no-underline transition-colors pt-2 pb-1',
            isActive(localePath(lang, '/company'))
              ? 'text-brand-700 border-b border-secondary-500'
              : 'text-stone-500 hover:text-brand-700 border-b border-transparent hover:border-secondary-300'
          ]}
        >
          {t('nav.company')}
        </a>

        <!-- Services dropdown -->
        <div class="relative group">
          <button
            id="services-menu-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="services-menu"
            class:list={[
              'flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-widest transition-colors pt-2 pb-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2',
              isServicesActive
                ? 'text-brand-700 border-b border-brand-500'
                : 'text-stone-500 hover:text-brand-700 border-b border-transparent hover:border-brand-300'
            ]}
          >
            {t('nav.services')}
            <svg class="w-3 h-3 mt-px opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div
            id="services-menu"
            role="menu"
            class="absolute top-full left-0 mt-1 w-52 bg-white border border-stone-200 shadow-sm hidden group-hover:block group-focus-within:block z-10 before:absolute before:content-[''] before:h-2 before:w-full before:-top-2 before:left-0 dropdown-animate"
          >
            <div class="h-px w-full bg-secondary-500"></div>
            {serviceLinks.map(({ href, label }) => (
              <a
                href={href}
                role="menuitem"
                class:list={[
                  'block px-5 py-3 text-[11px] font-semibold uppercase tracking-widest no-underline transition-colors border-l-2',
                  isActive(href)
                    ? 'text-brand-700 bg-brand-50 border-l-secondary-500'
                    : 'text-stone-600 hover:text-brand-700 hover:bg-stone-50 border-l-transparent hover:border-l-secondary-300'
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </div>

        <!-- Contacte -->
        <a
          href={localePath(lang, '/contact')}
          class:list={[
            'text-[11px] font-semibold uppercase tracking-widest no-underline transition-colors px-4 py-2 border',
            isActive(localePath(lang, '/contact'))
              ? 'bg-secondary-500 text-brand-900 border-secondary-500'
              : 'text-brand-700 border-brand-700 hover:bg-secondary-500 hover:text-brand-900 hover:border-secondary-500'
          ]}
        >
          {t('nav.contact')}
        </a>

        <!-- Language switcher -->
        <div class="relative group/lang">
          <button
            id="lang-menu-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="lang-menu"
            class="flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-widest text-stone-500 hover:text-brand-700 transition-colors py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
          >
            <img src={languageFlagImg[lang]} alt="" aria-hidden="true" class="w-5 h-3.5 object-cover rounded-sm" />
            {lang.toUpperCase()}
            <svg class="w-2.5 h-2.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div
            id="lang-menu"
            role="menu"
            class="absolute top-full right-0 mt-1 w-44 bg-white border border-stone-200 shadow-sm hidden group-hover/lang:block group-focus-within/lang:block z-10 before:absolute before:content-[''] before:h-2 before:w-full before:-top-2 before:left-0 dropdown-animate"
          >
            <div class="h-px w-full bg-secondary-500"></div>
            {locales.map((locale) => (
              <a
                href={getLocaleUrl(locale, pathname)}
                role="menuitem"
                hreflang={locale}
                class:list={[
                  'flex items-center gap-2.5 px-4 py-2.5 text-[11px] font-semibold uppercase tracking-widest no-underline transition-colors border-l-2',
                  locale === lang
                    ? 'text-brand-700 bg-brand-50 border-l-secondary-500'
                    : 'text-stone-600 hover:text-brand-700 hover:bg-stone-50 border-l-transparent hover:border-l-secondary-300'
                ]}
              >
                <img src={languageFlagImg[locale]} alt="" aria-hidden="true" class="w-5 h-3.5 object-cover rounded-sm flex-shrink-0" />
                {languageNames[locale]}
              </a>
            ))}
          </div>
        </div>

      </nav>

      <!-- Mobile: hamburger / close label -->
      <label for="mobile-menu" class="md:hidden cursor-pointer p-2 text-stone-500 hover:text-brand-700 transition-colors relative" aria-label={t('nav.openMenu')}>
        <svg class="nav-icon-open w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="nav-icon-close w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </label>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div class="mobile-nav-panel md:hidden border-t border-stone-100 bg-white">
    <nav class="max-w-6xl mx-auto px-4 py-2 flex flex-col text-[11px] font-semibold uppercase tracking-widest">

      <a
        href={localePath(lang, '/')}
        class:list={[
          'px-2 py-3.5 no-underline border-b border-stone-100 transition-colors',
          isActive(localePath(lang, '/')) ? 'text-brand-700' : 'text-stone-500 hover:text-brand-700'
        ]}
      >
        {t('nav.home')}
      </a>

      <a
        href={localePath(lang, '/company')}
        class:list={[
          'px-2 py-3.5 no-underline border-b border-stone-100 transition-colors',
          isActive(localePath(lang, '/company')) ? 'text-brand-700' : 'text-stone-500 hover:text-brand-700'
        ]}
      >
        {t('nav.company')}
      </a>

      <div class="px-2 pt-4 pb-1.5 text-[9px] text-stone-500 uppercase tracking-[0.25em]">{t('nav.services')}</div>
      {serviceLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-2 py-3 no-underline border-b border-stone-100 transition-colors pl-5',
            isActive(href) ? 'text-brand-700' : 'text-stone-500 hover:text-brand-700'
          ]}
        >
          {label}
        </a>
      ))}

      <a
        href={localePath(lang, '/contact')}
        class:list={[
          'mx-2 my-4 px-4 py-3 border text-center no-underline transition-colors',
          isActive(localePath(lang, '/contact'))
            ? 'bg-secondary-500 text-brand-900 border-secondary-500'
            : 'text-brand-700 border-brand-700 hover:bg-secondary-500 hover:text-brand-900 hover:border-secondary-500'
        ]}
      >
        {t('nav.contact')}
      </a>

      <!-- Mobile language switcher -->
      <div class="px-2 pt-2 pb-4 border-t border-stone-100 mt-1">
        <p class="text-[9px] text-stone-500 uppercase tracking-[0.25em] mb-2">Idioma / Language</p>
        <div class="flex gap-2.5 flex-wrap">
          {locales.map((locale) => (
            <a
              href={getLocaleUrl(locale, pathname)}
              hreflang={locale}
              class:list={[
                'flex items-center gap-1.5 px-3 py-2 text-[10px] font-semibold uppercase tracking-widest no-underline border transition-colors',
                locale === lang
                  ? 'bg-secondary-500 text-brand-900 border-secondary-500'
                  : 'text-stone-500 border-stone-200 hover:text-brand-700 hover:border-brand-300'
              ]}
            >
              <img src={languageFlagImg[locale]} alt="" aria-hidden="true" class="w-5 h-3.5 object-cover rounded-sm" />
              {locale.toUpperCase()}
            </a>
          ))}
        </div>
      </div>

    </nav>
  </div>
</header>

<script>
  // ── Mobile nav: animated open / close ────────────────────────
  const mobileCheckbox = document.getElementById('mobile-menu') as HTMLInputElement | null;
  const mobilePanel    = document.querySelector('.mobile-nav-panel') as HTMLElement | null;
  const mobileLabel    = document.querySelector('label[for="mobile-menu"]') as HTMLElement | null;

  if (mobileCheckbox && mobilePanel && mobileLabel) {
    const openPanel = () => {
      mobileCheckbox.checked = true;
      mobilePanel.classList.remove('is-closing');
      mobilePanel.classList.add('is-open');
    };

    const closePanel = () => {
      mobilePanel.classList.remove('is-open');
      mobilePanel.classList.add('is-closing');
      mobilePanel.addEventListener('animationend', () => {
        mobilePanel.classList.remove('is-closing');
        mobileCheckbox.checked = false;
      }, { once: true });
    };

    mobileLabel.addEventListener('click', (e) => {
      e.preventDefault();
      mobilePanel.classList.contains('is-open') ? closePanel() : openPanel();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobilePanel.classList.contains('is-open')) closePanel();
    });
  }

  // ── Desktop services dropdown ─────────────────────────────────
  const btn = document.getElementById('services-menu-btn');
  const menu = document.getElementById('services-menu');
  if (btn && menu) {
    const isExpanded = () => btn.getAttribute('aria-expanded') === 'true';
    const setExpanded = (val: boolean) => btn.setAttribute('aria-expanded', String(val));

    btn.addEventListener('mouseenter', () => setExpanded(true));
    btn.closest('.group')?.addEventListener('mouseleave', () => setExpanded(false));
    btn.addEventListener('click', () => setExpanded(!isExpanded()));
    btn.addEventListener('focus', () => setExpanded(true));

    menu.addEventListener('focusout', (e) => {
      if (!menu.contains((e as FocusEvent).relatedTarget as Node)) setExpanded(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isExpanded()) {
        setExpanded(false);
        btn.focus();
      }
    });
  }

  // ── Desktop language dropdown ─────────────────────────────────
  const langBtn = document.getElementById('lang-menu-btn');
  const langMenu = document.getElementById('lang-menu');
  if (langBtn && langMenu) {
    const isExpanded = () => langBtn.getAttribute('aria-expanded') === 'true';
    const setExpanded = (val: boolean) => langBtn.setAttribute('aria-expanded', String(val));

    langBtn.addEventListener('mouseenter', () => setExpanded(true));
    langBtn.closest('.group\\/lang')?.addEventListener('mouseleave', () => setExpanded(false));
    langBtn.addEventListener('click', () => setExpanded(!isExpanded()));
    langBtn.addEventListener('focus', () => setExpanded(true));

    langMenu.addEventListener('focusout', (e) => {
      if (!langMenu.contains((e as FocusEvent).relatedTarget as Node)) setExpanded(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isExpanded()) {
        setExpanded(false);
        langBtn.focus();
      }
    });
  }
</script>
