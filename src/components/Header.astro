---
const pathname = Astro.url.pathname;

const serviceLinks = [
  { href: '/services/water-management', label: "Gestió d'Aigua" },
  { href: '/services/environmental', label: 'Gestió Ambiental' },
  { href: '/services/engineering', label: 'Enginyeria' },
];

const isServicesActive = pathname.startsWith('/services');

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="bg-white border-b border-stone-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="text-xl font-semibold text-brand-700 hover:text-brand-500 no-underline tracking-tight">
        Àbiòtic
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
        <a
          href="/"
          class:list={['hover:text-brand-700 no-underline', isActive('/') ? 'text-brand-700 font-semibold' : 'text-stone-600']}
        >
          Inici
        </a>
        <a
          href="/company"
          class:list={['hover:text-brand-700 no-underline', isActive('/company') ? 'text-brand-700 font-semibold' : 'text-stone-600']}
        >
          L'empresa
        </a>

        <!-- Services dropdown -->
        <div class="relative group">
          <button
            id="services-menu-btn"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="services-menu"
            class:list={['flex items-center gap-1 hover:text-brand-700', isServicesActive ? 'text-brand-700 font-semibold' : 'text-stone-600']}
          >
            Serveis
            <svg class="w-3.5 h-3.5 mt-px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="services-menu"
            role="menu"
            class="absolute top-full left-0 mt-1 w-52 bg-white border border-stone-200 rounded-md shadow-md hidden group-hover:block group-focus-within:block z-10"
          >
            {serviceLinks.map(({ href, label }) => (
              <a
                href={href}
                role="menuitem"
                class:list={[
                  'block px-4 py-2.5 text-sm hover:bg-brand-50 hover:text-brand-700 no-underline',
                  isActive(href) ? 'text-brand-700 font-semibold bg-brand-50' : 'text-stone-700'
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </div>

        <a
          href="/contact"
          class:list={['hover:text-brand-700 no-underline', isActive('/contact') ? 'text-brand-700 font-semibold' : 'text-stone-600']}
        >
          Contacte
        </a>
      </nav>

      <!-- Mobile: checkbox hamburger (CSS-only, no JS) -->
      <label for="mobile-menu" class="md:hidden cursor-pointer p-2 text-stone-600 hover:text-brand-700" aria-label="Obrir menú">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
      <input type="checkbox" id="mobile-menu" class="hidden peer/menu" />
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div class="hidden peer-checked/menu:block md:hidden border-t border-stone-100 bg-white">
    <nav class="max-w-6xl mx-auto px-4 py-4 flex flex-col gap-1 text-sm font-medium">
      <a
        href="/"
        class:list={['px-3 py-2 rounded-md hover:bg-brand-50 hover:text-brand-700 no-underline', isActive('/') ? 'text-brand-700 font-semibold bg-brand-50' : 'text-stone-700']}
      >
        Inici
      </a>
      <a
        href="/company"
        class:list={['px-3 py-2 rounded-md hover:bg-brand-50 hover:text-brand-700 no-underline', isActive('/company') ? 'text-brand-700 font-semibold bg-brand-50' : 'text-stone-700']}
      >
        L'empresa
      </a>
      <div class="px-3 pt-3 pb-1 text-xs font-semibold text-stone-400 uppercase tracking-wider">Serveis</div>
      {serviceLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={['px-3 py-2 rounded-md hover:bg-brand-50 hover:text-brand-700 no-underline', isActive(href) ? 'text-brand-700 font-semibold bg-brand-50' : 'text-stone-700']}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class:list={['px-3 py-2 rounded-md hover:bg-brand-50 hover:text-brand-700 no-underline', isActive('/contact') ? 'text-brand-700 font-semibold bg-brand-50' : 'text-stone-700']}
      >
        Contacte
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('services-menu-btn');
  const menu = document.getElementById('services-menu');
  if (btn && menu) {
    const setExpanded = (val: boolean) => btn.setAttribute('aria-expanded', String(val));
    btn.addEventListener('mouseenter', () => setExpanded(true));
    btn.closest('.group')?.addEventListener('mouseleave', () => setExpanded(false));
    btn.addEventListener('focus', () => setExpanded(true));
    menu.addEventListener('focusout', (e) => {
      if (!menu.contains((e as FocusEvent).relatedTarget as Node)) setExpanded(false);
    });
  }
</script>
