---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
}

const { title, subtitle, eyebrow } = Astro.props;
---

<section class="relative bg-white overflow-hidden border-b border-stone-100">
  <!-- Grid texture — matches home/contact hero -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(to right, #e7e5e4 1px, transparent 1px), linear-gradient(to bottom, #e7e5e4 1px, transparent 1px); background-size: 80px 80px; opacity: 0.35;"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <!-- Eyebrow -->
    <div class="flex items-center gap-4 mb-8">
      <div class="w-8 h-px bg-brand-500"></div>
      <span class="text-brand-600 text-xs font-semibold uppercase tracking-[0.2em]">
        {eyebrow ?? title}
      </span>
    </div>

    <h1 class="font-display text-5xl sm:text-6xl font-medium text-stone-900 leading-[1.15] max-w-2xl">
      {title}
    </h1>

    {subtitle && (
      <p class="mt-6 text-stone-500 text-lg leading-relaxed max-w-xl">{subtitle}</p>
    )}
  </div>
</section>
